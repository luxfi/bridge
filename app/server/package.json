{
  "name": "@luxbridge/server",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "_moduleAliases": {
    "@": "dist"
  },
  "scripts": {
    "dev": "nodemon",
    "db": "node dist/db.js",
    "rm": "node dist/delete.js",
    "nodes": "node dist/nodes.js",
    "tc": "tsc",
    "typecheck": "tsc",
    "clean": "rm -rf ./node_modules",
    "prisma:gen": "pnpm exec prisma generate",
    "build": "pnpm exec prisma generate && tsc && tsc-alias",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "format": "eslint src/**/*.ts --fix",
    "update-db": "kubectl exec -it $(kubectl get pod -l app=bridge-server -o jsonpath='{.items[0].metadata.name}') -- pnpm run db",
    "colima:start": "colima start --arch aarch64,x86_64",
    "docker:build": "cd ../.. && docker buildx build --load --platform linux/amd64 -t ghcr.io/luxfi/bridge-server:latest -f app/server/docker/Dockerfile .",
    "docker:login": "docker login --username $GH_USER --password $GH_TOKEN ghcr.io",
    "docker:push": "docker push ghcr.io/luxfi/bridge/server:latest",
    "k8s:apply": "kubectl apply -f k8s/bridge-deployment.yaml && kubectl apply -f k8s/bridge-service.yaml",
    "k8s:logs": "kubectl logs -l app=bridge-server -f",
    "k8s:scale": "kubectl scale deployment bridge-server --replicas=$REPLICAS",
    "k8s:create-secret": "kubectl create secret generic bridge-server-secret --from-literal=POSTGRESQL_URL=\"$POSTGRESQL_URL\" --dry-run=client -o yaml | kubectl apply -f -",
    "k8s:restart": "kubectl rollout restart deployment bridge-server",
    "k8s:status": "kubectl get deployments,service,pods -l app=bridge-server -o wide",
    "k8s:stop": "kubectl delete deployment bridge-server || true && kubectl delete service bridge-service || true"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
